# ========== 数据库 ==========
DATABASE_URL=postgresql+asyncpg://mta_user:mta_password@localhost:5432/mta_db

# ========== 向量数据库 ==========
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ========== Redis ==========
REDIS_URL=redis://localhost:6379/0

# ========== 阿里百炼平台 ==========
BAILIAN_API_KEY=your_api_key_here
BAILIAN_EMBEDDING_MODEL=text-embedding-v3
BAILIAN_LLM_MODEL=qwen-plus

# ========== 应用配置 ==========
APP_ENV=development
APP_SECRET_KEY=change-me-to-a-random-string
APP_DEBUG=true
